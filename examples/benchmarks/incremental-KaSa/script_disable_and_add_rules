#!/bin/bash

## BENCHMARKS for the incremental implementation of KaSa, for the Tool paper at CMSB2026

# It analyzer 6 large Kappa models in 4 different ways:
# 1) non-incremental analysis
# 2) incremental analysis with 10 random rules in the working set
# 3) given the incremetal analysis with 10 rules in the working set, it disables some of the rules
# 4) I re-do the incremental analysis with 10 rules in the working set and one random rule removed. This one rule is added with "update file" to find out how much time it takes to add rules.

# The output is in output/experiments_output.tex

DEBUG=false
INSTALL_DEPS=false

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PWD=$(pwd)
SCRIPT_DIR=$(realpath "$SCRIPT_DIR" --relative-to="$PWD")

KASA_BINARY="${SCRIPT_DIR}/../../../bin/KaSa"
KASA_INC_BINARY="${SCRIPT_DIR}/../../../bin/KaSaIncremental"
KAPPA_OUTPUT_DIR="${SCRIPT_DIR}/../../../output/"
INPUT_INCREMENTAL_TMP="${MODELS_DIRECTORY}inc_analysis_input_tmp.txt"

# default values for variables
TIMEOUT=50m
REPS=10 # how often to repeat each experiment
NR_RULES=10 # how many rules to remove

# help message
print_help() {
    cat << EOF
Usage: ${0} [options]

Options:
  -t <timeout>   Set timeout value (default: $TIMEOUT)
  -r <int>       Set how many reps to do for each experiment (default: $REPS)
  -s <int>       Set how many rules to remove in each experiment (default: $NR_RULES)
  -i             Install dependencies before building and running
  -d             Set DEBUG to true (it runs the analysis with less reps, smaller models and more verbose output)
  -h             Show this help message and exit
EOF
}

# parse arguments
while getopts ":t:r:s:idh" opt; do
    case "$opt" in
        t)
            TIMEOUT="$OPTARG"
            ;;
        r)
            REPS="$OPTARG"
            ;;
        s)
            NR_RULES="$OPTARG"
            ;;
        i)
            INSTALL_DEPS=true
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_help
            exit 0
            ;;
        \?)
            echo "Error: Invalid option -$OPTARG" >&2
            print_help
            exit 1
            ;;
        :)
            echo "Error: Option -$OPTARG requires an argument" >&2
            print_help
            exit 1
            ;;
    esac
done

if $DEBUG ; then
    TIMEOUT=3m
    REPS=2
    NR_RULES=10
fi

shift $((OPTIND - 1))

echo "Benchmarks for the incremental KaSa tool."
echo "Using a timeout of $TIMEOUT."
echo "Using $NR_RULES rules in the working set."
echo "Performing $REPS repetitions for each experiment."

OPTIONS="--reset-all --compute-reachability-analysis --enable-every-domain --print-efficiency"
# models
MODELS_DIRECTORY="${SCRIPT_DIR}/models/"

egfr_net="${MODELS_DIRECTORY}egfr_net.ka" # small model for debugging this script

korkut_20170206="${MODELS_DIRECTORY}korkut/20170206/korkut_model.ka"
korkut_20170113="${MODELS_DIRECTORY}korkut/20170113/prior_model.ka"
wnt_20170322="${MODELS_DIRECTORY}wnt/20170322/full_model.ka"
wnt_20151228="${MODELS_DIRECTORY}wnt/20151228/model_bigwnt.ka"
tgf_v19="${MODELS_DIRECTORY}tgf/V19/NTactivationTGF_19.ka"
tgf_20180419="${MODELS_DIRECTORY}tgf/20180419/full.ka"

korkut_20170206_nr_rules=5750
korkut_20170113_nr_rules=3916
wnt_20170322_nr_rules=1470
wnt_20151228_nr_rules=356
egfr_net_nr_rules=23
tgf_20180419_nr_rules=292
tgf_v19_nr_rules=97

# Array of models
MODELS=("tgf_v19" "tgf_20180419" "wnt_20151228" "wnt_20170322" "korkut_20170113" "korkut_20170206")

OUTPUT_DIR="${SCRIPT_DIR}/output/"
PROFILING_FILE="${KAPPA_OUTPUT_DIR}profiling.html"

if $DEBUG ; then
    MODELS=("egfr_net" "tgf_v19")
fi

AVAILABLE_MODELS=$(printf "%s, " "${MODELS[@]}")
AVAILABLE_MODELS=${AVAILABLE_MODELS%, }

# Install the dependencies
if $INSTALL_DEPS; then
    cd "${SCRIPT_DIR}/../../.."
    echo "Installing dependencies:"
    opam install . --update-invariant
fi

# Build Kappa
if ! $DEBUG; then
    echo
    echo "Building the project:"
    make all
fi

mkdir -p "${OUTPUT_DIR}"

echo
echo "Analyzing models: $AVAILABLE_MODELS"

GLOBAL_OUTPUT_FILE="${OUTPUT_DIR}experiments_output.csv"
echo "model,nr_rules,analysis_type,step_name,substep_name,rep,nr_removed_rules,time" > "$GLOBAL_OUTPUT_FILE"

store_runtime_from_profiling () {
    # take the line we are interested in from profiling.html and copy the runtime to the output file in a csv format
    grep --text "End</TD><TD>$1" "$PROFILING_FILE" | tail -1 | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$2,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
}

# Analyze each model
for MODEL in "${MODELS[@]}"; do
    EXAMPLE_MODEL=${!MODEL}
    var_tmp="${MODEL}_nr_rules"
    value_tmp=${!var_tmp}
    NR_RULES_MODEL=$((value_tmp-1))

    echo
    echo "Processing model: $MODEL ($value_tmp rules)"

    # define output files (for the stdout output of the analysis)
    OUTPUT_FILE="${OUTPUT_DIR}${MODEL}_experiments_output"
    STDOUT_OUTPUT_FILE_FULL="${OUTPUT_FILE}_full.txt"
    STDOUT_OUTPUT_FILE_DECREMENTAL="${OUTPUT_FILE}_decremental.txt"
    STDOUT_OUTPUT_FILE_INCREMENTAL="${OUTPUT_FILE}_incremental.txt"

    # clear output files
    echo -n "" > "$STDOUT_OUTPUT_FILE_FULL"
    echo -n "" > "$STDOUT_OUTPUT_FILE_DECREMENTAL"
    echo -n "" > "$STDOUT_OUTPUT_FILE_INCREMENTAL"

    # Find the syntax version (no guarantees)
    SYNTAX="V4"
    if grep -v "^/\*" "$EXAMPLE_MODEL" | grep -qi "!1" -; then
        SYNTAX="V3"
    fi

    for (( i=1; i<=REPS; i++ )) # take the mean runtime of multiple repetitions
    do
        # NON-INCREMENTAL ANALYSIS

        if $DEBUG; then
            echo "⌛ Starting non-incremental analysis:"
        fi

        cmd=(
            timeout "$TIMEOUT"
            "$KASA_BINARY"
            "$EXAMPLE_MODEL"
            -syntax "$SYNTAX"
            $OPTIONS

            )
        if $DEBUG; then
            printf '%q ' "${cmd[@]}"
            printf '\n'
        fi
        { ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_FULL"
        EXIT_STATUS=$?

        # copy runtimes from output/profiling.html to the csv output file

        store_runtime_from_profiling "Global initialization" "$MODEL,$NR_RULES_MODEL,1_full,1_init,1_initialization,$i,$NR_RULES"
        store_runtime_from_profiling "Initial states computation" "$MODEL,$NR_RULES_MODEL,1_full,1_init,2_initial_state,$i,$NR_RULES"
        store_runtime_from_profiling "Compute fixpoint of reachability analysis" "$MODEL,$NR_RULES_MODEL,1_full,1_init,3_fixpoint,$i,$NR_RULES"
        store_runtime_from_profiling "Print result of reachability analysis" "$MODEL,$NR_RULES_MODEL,1_full,1_init,4_print,$i,$NR_RULES"

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL (full non-incremental analysis)."
            break
        fi

        
        # DECREMENTAL ANALYSIS

        if $DEBUG; then
            echo "➖ Starting decremental analysis:"
        fi
        
        # choose 10 random rules to be added to the working set
        random_rules=$(shuf -i 0-$NR_RULES_MODEL -n "$NR_RULES" | paste -sd,)

        if $DEBUG; then 
            echo "Random list of rules that are in the working set: $random_rules"
        fi

        # choose a random valuation (true or false) for each of the rules in the working set
        false_indices=()
        for ((n=0; n<NR_RULES; n++)); do
            val=$((RANDOM % 2))
            if [ "$val" -eq 0 ]; then
                false_indices+=("$n")
            fi
        done
        disabled_rules=$(printf "%s," "${false_indices[@]}")
        disabled_rules=${disabled_rules%,}

        if $DEBUG; then
            echo "Random list of working set indices that will be disabled: $disabled_rules"
        fi

        echo "disable $disabled_rules" > "$INPUT_INCREMENTAL_TMP"
        echo "q" >> "$INPUT_INCREMENTAL_TMP"
        
        if $DEBUG; then
            echo "DECREMENTAL COMMANDS:"
            cat "$INPUT_INCREMENTAL_TMP"
        fi

        cmd=(
        timeout "$TIMEOUT"
        "$KASA_INC_BINARY"
        "$EXAMPLE_MODEL"
        -syntax "$SYNTAX"
        $OPTIONS
        --rules-in-working-set "$random_rules"
        )
        if $DEBUG; then
            printf '%q ' cat "$INPUT_INCREMENTAL_TMP" '|' "${cmd[@]}"
            printf '\n'
        fi
        { cat "$INPUT_INCREMENTAL_TMP" | ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_DECREMENTAL"
        EXIT_STATUS=$?

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL in the decremental analysis."
            break
        fi

        # copy runtimes from output/profiling.html to the csv output file
        # initial analysis
        store_runtime_from_profiling "Global initialization" "$MODEL,$NR_RULES_MODEL,2_decremental,1_init,1_initialization,$i,$NR_RULES"
        store_runtime_from_profiling "Initial states computation" "$MODEL,$NR_RULES_MODEL,2_decremental,1_init,2_initial_state,$i,$NR_RULES"
        store_runtime_from_profiling "Compute fixpoint of reachability analysis" "$MODEL,$NR_RULES_MODEL,2_decremental,1_init,3_fixpoint,$i,$NR_RULES"
        # projection to the chosen valuation (and printing)
        store_runtime_from_profiling "Enable or disable a rule" "$MODEL,$NR_RULES_MODEL,2_decremental,4_disable,4_disable,$i,$NR_RULES"
        store_runtime_from_profiling "Print result of reachability analysis" "$MODEL,$NR_RULES_MODEL,2_decremental,4_disable,5_print,$i,$NR_RULES" 

        # INCREMENTAL ADDING OFcode RULES
        # I redo the analysis instead of just adding the rules to he previous instance of the analysis, because the "update file" resets the profiling.html

        if $DEBUG; then
            echo "➕ Starting incremental analysis:"
        fi

        # we take the model with 1 rule removed and then compute the time it takes to add it
        echo "update file $EXAMPLE_MODEL" > "$INPUT_INCREMENTAL_TMP"
        echo "q" >> "$INPUT_INCREMENTAL_TMP"

        # choose the last element of the working set and remove it from the model
        last_element=${random_rules##*,}

        if $DEBUG; then
            echo "Removed rule:"
            echo "$last_element"
            echo "INCREMENTAL COMMANDS:"
            cat "$INPUT_INCREMENTAL_TMP"
        fi

        cmd=(
        timeout "$TIMEOUT"
        "$KASA_INC_BINARY"
        "$EXAMPLE_MODEL"
        -syntax "$SYNTAX"
        $OPTIONS
        --rules-in-working-set "$random_rules"
        --remove-rules "$last_element"
        )
        if $DEBUG; then
            printf '%q ' cat "$INPUT_INCREMENTAL_TMP" '|' "${cmd[@]}"
            printf '\n'
        fi
        { cat "$INPUT_INCREMENTAL_TMP" | ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_INCREMENTAL"
        EXIT_STATUS=$?

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL in the incremental analysis."
            break
        fi

        # copy runtimes from output/profiling.html to the csv output file
        store_runtime_from_profiling "Update global initialization" "$MODEL,$NR_RULES_MODEL,3_incremental,1_init,1_initialization,$i,$NR_RULES"
        store_runtime_from_profiling "Add new initial states computation" "$MODEL,$NR_RULES_MODEL,3_incremental,1_init,2_initial_state,$i,$NR_RULES"
        store_runtime_from_profiling "Restart fixpoint computation for the reachability analysis" "$MODEL,$NR_RULES_MODEL,3_incremental,1_init,3_fixpoint,$i,$NR_RULES"
        store_runtime_from_profiling "Print result of reachability analysis" "$MODEL,$NR_RULES_MODEL,3_incremental,1_init,5_print,$i,$NR_RULES"

    done

    rm "$INPUT_INCREMENTAL_TMP"

    echo "✅ Completed: $MODEL"
    echo "Results of the non-incremental analysis: $STDOUT_OUTPUT_FILE_FULL"
    echo "Results of the decremental analysis: $STDOUT_OUTPUT_FILE_DECREMENTAL"
    echo "Results of the incremental analysis: $STDOUT_OUTPUT_FILE_INCREMENTAL"
done

# compute the mean runtime of the multiple repetitions
python3 examples/benchmarks/incremental-KaSa/mean_of_reps.py

OUTPUT_MEAN_RUNTIMES="${OUTPUT_DIR}experiments_output_mean.csv"

echo
echo "📝 The mean of all runtimes can be found in: $OUTPUT_MEAN_RUNTIMES"

OUTPUT_LATEX_RUNTIMES="${OUTPUT_DIR}experiments_output.tex"

# draw a latex table with the runtimes

cmd=(python3 
    "${SCRIPT_DIR}/latex_table_of_runtimes.py" 
    "$OUTPUT_MEAN_RUNTIMES" "$OUTPUT_LATEX_RUNTIMES"
    )
printf '%q ' "${cmd[@]}"
printf '\n'
{ ${cmd[@]}; }

echo "📊 The latex table of the runtimes can be found in: $OUTPUT_LATEX_RUNTIMES"

