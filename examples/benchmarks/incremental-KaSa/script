#!/bin/bash

DEBUG=false
INSTALL_DEPS=false

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

KASA_BINARY="${SCRIPT_DIR}/../../../bin/KaSa"
KASA_INC_BINARY="${SCRIPT_DIR}/../../../bin/KaSaIncremental"
KAPPA_OUTPUT_DIR="${SCRIPT_DIR}/../../../output/"
INPUT_INCREMENTAL_TMP="${MODELS_DIRECTORY}inc_analysis_input_tmp.txt"

# default values for variables
TIMEOUT=3m
REPS=2 # how often to repeat each experiment
NR_RULES=10 # how many rules to remove

# help message
print_help() {
    cat << EOF
Usage: ${0} [options]

Options:
  -t <timeout>   Set timeout value (default: $TIMEOUT)
  -r <int>       Set how many reps to do for each experiment (default: $REPS)
  -s <int>       Set how many rules to remove in each experiment (default: $NR_RULES)
  -i             Install dependencies before building and running
  -d             Set DEBUG to true
  -h             Show this help message and exit
EOF
}

# parse arguments
while getopts ":t:r:s:idh" opt; do
    case "$opt" in
        t)
            TIMEOUT="$OPTARG"
            ;;
        r)
            REPS="$OPTARG"
            ;;
        s)
            NR_RULES="$OPTARG"
            ;;
        i)
            INSTALL_DEPS=true
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_help
            exit 0
            ;;
        \?)
            echo "Error: Invalid option -$OPTARG" >&2
            print_help
            exit 1
            ;;
        :)
            echo "Error: Option -$OPTARG requires an argument" >&2
            print_help
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

echo "Using a timeout of $TIMEOUT."
echo "Using $NR_RULES rules in the working set."
echo "Performing $REPS repetitions for each experiment."

OPTIONS="--reset-all --compute-reachability-analysis --enable-every-domain"
# models
MODELS_DIRECTORY="${SCRIPT_DIR}/models/"
V3_MODELS_DIRECTORY="${MODELS_DIRECTORY}examples-for-incremental-analysis/"

ENSEMBLE="${MODELS_DIRECTORY}ensemble.ka"
EGFR="${MODELS_DIRECTORY}causality_05_sos.ka"
REPRESSILATOR="${MODELS_DIRECTORY}Repressilator.ka"
FGF="${MODELS_DIRECTORY}fgf.ka"
SFB="${MODELS_DIRECTORY}sfb.ka"

egfr_net="${V3_MODELS_DIRECTORY}BNGL/egfr_net.ka"
fceri_fyn="${V3_MODELS_DIRECTORY}BNGL/fceri_fyn.ka"
fceri_fyn_lig="${V3_MODELS_DIRECTORY}BNGL/fceri_fyn_lig.ka"
fceri_fyn_trimer="${V3_MODELS_DIRECTORY}BNGL/fceri_fyn_trimer.ka"
fceri_gamma2="${V3_MODELS_DIRECTORY}BNGL/fceri_gamma2.ka"
fceri_ji="${V3_MODELS_DIRECTORY}BNGL/fceri_ji.ka"
machine="${V3_MODELS_DIRECTORY}large/machine/machine.ka"
ensemble="${V3_MODELS_DIRECTORY}large/ensemble/ensemble.ka"

korkut_20170206="${MODELS_DIRECTORY}korkut/20170206/korkut_model.ka"
korkut_20170113="${MODELS_DIRECTORY}korkut/20170113/prior_model.ka"
wnt_20170322="${MODELS_DIRECTORY}wnt/20170322/full_model.ka"
wnt_20151228="${MODELS_DIRECTORY}wnt/20151228/model_bigwnt.ka"

# To find the number of rules (not fool-proo):
# grep -v "^#" model | grep -c "->" -
korkut_20170206_nr_rules=5750
korkut_20170113_nr_rules=3916
wnt_20170322_nr_rules=1470
wnt_20151228_nr_rules=356
egfr_net_nr_rules=23

# Array of models
MODELS=("korkut_20170113" "korkut_20170206" "wnt_20151228" "wnt_20170322")
OTHER_AVAILABLE_MODELS=("egfr_net" "fceri_fyn" "fceri_fyn_lig" "fceri_fyn_trimer" "fceri_gamma2" "ENSEMBLE" "EGFR" "REPRESSILATOR" "FGF" "SFB" "fceri_ji" "machine" "ensemble")

OUTPUT_DIR="${SCRIPT_DIR}/output/"
PROFILING_FILE="${KAPPA_OUTPUT_DIR}profiling.html"

if $DEBUG ; then
    MODELS=("egfr_net")
fi

AVAILABLE_MODELS=$(printf "%s, " "${MODELS[@]}")
AVAILABLE_MODELS=${AVAILABLE_MODELS%, }

if $INSTALL_DEPS; then
    cd "${SCRIPT_DIR}/../../.."
    # Install the dependencies
    echo "Installing dependencies:"
    opam install . --update-invariant
fi

if ! $DEBUG; then
    echo
    # Build Kappa
    echo "Building the project:"
    make all
fi

mkdir -p "${OUTPUT_DIR}"

echo
echo "Analyzing models: $AVAILABLE_MODELS"

GLOBAL_OUTPUT_FILE="${OUTPUT_DIR}experiments_output.csv"
echo "model,nr_rules,analysis_type,step_name,rep,nr_removed_rules,time" > "$GLOBAL_OUTPUT_FILE"

# Analyze each model
for MODEL in "${MODELS[@]}"; do
    EXAMPLE_MODEL=${!MODEL}
    var_tmp="${MODEL}_nr_rules"
    value_tmp=${!var_tmp}
    NR_RULES_MODEL=$(($value_tmp-1))

    echo
    echo "Processing model: $MODEL ($value_tmp rules)"

    # output files
    OUTPUT_FILE="${OUTPUT_DIR}${MODEL}_experiments_output"
    i=0
    while [ -e "${OUTPUT_FILE}_full~$i.txt" ]; do
        i=$((i + 1))
    done
    STDOUT_OUTPUT_FILE_FULL="${OUTPUT_FILE}_full~$i.txt"
    STDOUT_OUTPUT_FILE_REMOVED_RULES="${OUTPUT_FILE}_removed_rules~$i.txt"
    STDOUT_OUTPUT_FILE_INCREMENTAL="${OUTPUT_FILE}_incremental~$i.txt"
    OUTPUT_FILE="${OUTPUT_DIR}${MODEL}_runtimes~$i.html"

    SYNTAX="V4"
    if grep -qi "!1" "$EXAMPLE_MODEL"; then
        SYNTAX="V3"
    fi

    for (( i=1; i<=$REPS; i++ ))
    do
        # CLASSICAL ANALYSIS
        if $DEBUG; then
            echo "⌛ Starting non-incremental analysis:"
        fi

        cmd=(
            timeout "$TIMEOUT"
            "$KASA_BINARY"
            "$EXAMPLE_MODEL"
            -syntax "$SYNTAX"
            $OPTIONS
            )
        printf '%q ' "${cmd[@]}"
        printf '\n'
        { ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_FULL"
        EXIT_STATUS=$?

        echo "<h4>FULL NON INCREMENTAL ANALYSIS</h4><table>" >> "${OUTPUT_FILE}"
        grep "Global initialization" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,1_full,1_init,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Initial states computation" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,1_full,2_init2,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Compute fixpoint of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,1_full,3_fixpoint,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Print result of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,1_full,4_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        echo "</table>" >> "${OUTPUT_FILE}"

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL (non-incremental analysis 1)."
            break
        fi

        if $DEBUG; then
            echo "⌛ Starting non-incremental analysis with removed rules:"
        fi

        random_rules=$(shuf -i 0-$NR_RULES_MODEL -n $NR_RULES | paste -sd,)

        if $DEBUG; then
            echo "Random list of rules that are removed: $random_rules"
        fi

        cmd=(
        timeout "$TIMEOUT"
        "$KASA_BINARY"
        "$EXAMPLE_MODEL"
        -syntax "$SYNTAX"
        $OPTIONS
        --remove-rules "$random_rules"
        )
        printf '%q ' "${cmd[@]}"
        printf '\n'
        { ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_REMOVED_RULES"
        EXIT_STATUS=$?

        echo "<h4>NON INCREMENTAL ANALYSIS WITH REMOVED RULES</h4><table>" >> "${OUTPUT_FILE}"
        grep "Global initialization" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,2_partial,1_init,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Initial states computation" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,2_partial,2_init2,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Compute fixpoint of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,2_partial,3_fixpoint,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Print result of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,2_partial,4_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        echo "</table>" >> "${OUTPUT_FILE}"


        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL (non-incremental analysis 2)."
            break
        fi

        # INCREMENTAL ANALYSIS
        if $DEBUG; then
            echo "⚡️ Starting incremental analysis:"
        fi

        echo -n "disable 0" > "$INPUT_INCREMENTAL_TMP"
        for (( jj=1; jj<$NR_RULES; jj++ ))
        do
            echo -n  ",$jj" >> "$INPUT_INCREMENTAL_TMP"
        done
        echo "" >> "$INPUT_INCREMENTAL_TMP"
        echo "print result" >> "$INPUT_INCREMENTAL_TMP"
        echo "q" >> "$INPUT_INCREMENTAL_TMP"
        
        if $DEBUG; then
            echo "INCREMENTAL COMMANDS:"
            cat "$INPUT_INCREMENTAL_TMP"
        fi

        cmd=(
        timeout "$TIMEOUT"
        "$KASA_INC_BINARY"
        "$EXAMPLE_MODEL"
        -syntax "$SYNTAX"
        $OPTIONS
        --rules-in-working-set "$random_rules"
        )
        printf '%q ' cat "$INPUT_INCREMENTAL_TMP" '|' "${cmd[@]}"
        printf '\n'
        { cat "$INPUT_INCREMENTAL_TMP" | ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_INCREMENTAL"
        EXIT_STATUS=$?

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL in the incremental analysis."
            break
        fi

        echo "<h4>INCREMENTAL ANALYSIS</h4><table>" >> "${OUTPUT_FILE}"

        grep "Global initialization" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,1_init,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "Initial states computation" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,2_init2,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep -m 2 "Compute fixpoint of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep -m 1 "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,3_fixpoint,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep -m 2 "Print result of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep -m 1 "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,4_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep "Enable or disable a rule" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Enable or disable a rule" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,5_disable,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep "Print result of reachability analysis" "$PROFILING_FILE" | tail -2 >> "${OUTPUT_FILE}"
        echo "</table>" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | tail -1 | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$MODEL,$NR_RULES_MODEL,3_incremental,6_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

    done

    rm $INPUT_INCREMENTAL_TMP

    echo "✅ Completed: $MODEL"
    echo "The results of the incremental analysis can be found in: $STDOUT_OUTPUT_FILE_INCREMENTAL"
    echo "And those of the non-incremental analysis in: $STDOUT_OUTPUT_FILE_FULL and $STDOUT_OUTPUT_FILE_REMOVED_RULES"
    echo "The runtimes can be found in: $OUTPUT_FILE"

    # Check for exceptions in STDOUT_OUTPUT_FILE
    if grep -qi "exception:" "$STDOUT_OUTPUT_FILE_FULL"; then
        echo "🚨 Exception raised during analysis of $MODEL 1."
    fi
    if grep -qi "exception:" "$STDOUT_OUTPUT_FILE_REMOVED_RULES"; then
        echo "🚨 Exception raised during analysis of $MODEL 2."
    fi
    if grep -qi "exception:" "$STDOUT_OUTPUT_FILE_INCREMENTAL"; then
        echo "🚨 Exception raised during analysis of $MODEL 3."
    fi 

done

python3 examples/benchmarks/incremental-KaSa/mean_of_reps.py

OUTPUT_MEAN_RUNTIMES="${OUTPUT_DIR}experiments_output_mean.csv"

echo
echo "📝 The mean of all runtimes can be found in: $OUTPUT_MEAN_RUNTIMES"

OUTPUT_LATEX_RUNTIMES="${OUTPUT_DIR}experiments_output.tex"

python3 examples/benchmarks/incremental-KaSa/latex_table_of_runtimes.py $OUTPUT_MEAN_RUNTIMES $OUTPUT_LATEX_RUNTIMES

echo "📊 The latex table of the runtimes can be found in: $OUTPUT_LATEX_RUNTIMES"

