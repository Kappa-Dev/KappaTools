%def: "seed" "858703540"
%def: "dumpIfDeadlocked" "true"
%def: "maxConsecutiveClash" "3"
%def: "progressBarSize" "70"
%def: "progressBarSymbol" "#"
%def: "plotPeriod" "20" "t.u."
%def: "outputFileName" "data.csv"

%agent: A(x[x.C] y[y.B])
%agent: B(y[y.A])
%agent: C(x[x.A])

%plot: [T]
'name 1' A(x[./1]), C(x[./1]) @ 1
'name 1_op' A(x[1/.]), C(x[1/.]) @ 1
A(x[.] y[./1]), B(y[./1]) @ 1
A(x[.] y[1/.]), B(y[1/.]) @ 1
'name 3' A(y[./1]), B(y[./1]) @ 1
'name 3_op' A(y[1/.]), B(y[1/.]) @ 1


%init: 100 A(x[.] y[.]), B(y[.]), C(x[.])

%mod: [E] = 760408 do $STOP;
