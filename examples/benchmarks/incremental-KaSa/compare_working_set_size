#!/bin/bash

DEBUG=false
INSTALL_DEPS=false

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

KASA_BINARY="${SCRIPT_DIR}/../../../bin/KaSa"
KASA_INC_BINARY="${SCRIPT_DIR}/../../../bin/KaSaIncremental"
KAPPA_OUTPUT_DIR="${SCRIPT_DIR}/../../../output/"
INPUT_INCREMENTAL_TMP="${MODELS_DIRECTORY}inc_analysis_input_tmp.txt"

# default values for variables
TIMEOUT=3m
REPS=2 # how often to repeat each experiment

# help message
print_help() {
    cat << EOF
Usage: ${0} [options]

Options:
  -t <timeout>   Set timeout value (default: $TIMEOUT)
  -r <int>       Set how many reps to do for each experiment (default: $REPS)
  -i             Install dependencies before building and running
  -d             Set DEBUG to true
  -h             Show this help message and exit
EOF
}

# parse arguments
while getopts ":t:r:idh" opt; do
    case "$opt" in
        t)
            TIMEOUT="$OPTARG"
            ;;
        r)
            REPS="$OPTARG"
            ;;
        i)
            INSTALL_DEPS=true
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_help
            exit 0
            ;;
        \?)
            echo "Error: Invalid option -$OPTARG" >&2
            print_help
            exit 1
            ;;
        :)
            echo "Error: Option -$OPTARG requires an argument" >&2
            print_help
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

MIN_NR_RULES=10
MAX_NR_RULES=100
STEP=10

if $DEBUG; then
    MIN_NR_RULES=1
    MAX_NR_RULES=5
    STEP=1
fi

echo "Using a timeout of $TIMEOUT."
echo "Using $MIN_NR_RULES to $MAX_NR_RULES rules in the working set, with a step of $STEP."
echo "Performing $REPS repetitions for each experiment."

OPTIONS="--reset-all --compute-reachability-analysis --enable-every-domain"
# models
MODELS_DIRECTORY="${SCRIPT_DIR}/models/"

egfr_net="${MODELS_DIRECTORY}egfr_net.ka"

korkut_20170206="${MODELS_DIRECTORY}korkut/20170206/korkut_model.ka"


# Array of models
MODEL="korkut_20170206"
NR_RULES_MODEL=5750

OUTPUT_DIR="${SCRIPT_DIR}/output/"
PROFILING_FILE="${KAPPA_OUTPUT_DIR}profiling.html"

if $DEBUG ; then
    MODEL="egfr_net"
    NR_RULES_MODEL=23
fi

if $INSTALL_DEPS; then
    cd "${SCRIPT_DIR}/../../.."
    # Install the dependencies
    echo "Installing dependencies:"
    opam install . --update-invariant
fi

if ! $DEBUG; then
    echo
    # Build Kappa
    echo "Building the project:"
    make all
fi

mkdir -p "${OUTPUT_DIR}"

echo
echo "Analyzing model $MODEL."

GLOBAL_OUTPUT_FILE="${OUTPUT_DIR}experiments_output.csv"
echo "analysis_type,step_name,substep_name,rep,nr_removed_rules,time" > "$GLOBAL_OUTPUT_FILE"

EXAMPLE_MODEL=${!MODEL}

# Analyze the model for each size of working set
for ((NR_RULES=MIN_NR_RULES; NR_RULES <= MAX_NR_RULES; NR_RULES=NR_RULES+STEP)) do
    echo
    echo "Processing model: $MODEL with $NR_RULES rules in the working set"

    # output files
    OUTPUT_FILE="${OUTPUT_DIR}${NR_RULES}_rules_in_ws_experiments_output"
    i=0
    while [ -e "${OUTPUT_FILE}_full~$i.txt" ]; do
        i=$((i + 1))
    done
    STDOUT_OUTPUT_FILE_FULL="${OUTPUT_FILE}_full~$i.txt"
    STDOUT_OUTPUT_FILE_INCREMENTAL="${OUTPUT_FILE}_incremental~$i.txt"
    OUTPUT_FILE="${OUTPUT_DIR}${MODEL}_runtimes~$i.html"

    SYNTAX="V4"
    if grep -v "^/\*" "$EXAMPLE_MODEL" | grep -qi "!1" -; then
        SYNTAX="V3"
    fi

    for (( i=1; i<=REPS; i++ ))
    do
        # CLASSICAL ANALYSIS
        if $DEBUG; then
            echo "⌛ Starting non-incremental analysis:"
        fi

        cmd=(
            timeout "$TIMEOUT"
            "$KASA_BINARY"
            "$EXAMPLE_MODEL"
            -syntax "$SYNTAX"
            $OPTIONS
            )
        printf '%q ' "${cmd[@]}"
        printf '\n'
        { ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_FULL"
        EXIT_STATUS=$?

        echo "<h4>FULL NON INCREMENTAL ANALYSIS</h4><table>" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/1_full,1_init,1_initialization,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/1_full,1_init,2_initial_state,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/1_full,1_init,3_fixpoint,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        echo "</table>" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/1_full,3_print,4_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL with $NR_RULES rules in the working set (non-incremental analysis 1)."
            break
        fi

        random_rules=$(shuf -i "0-$NR_RULES_MODEL" -n $NR_RULES | paste -sd,)

        # INCREMENTAL ANALYSIS
        if $DEBUG; then
            echo "⚡️ Starting incremental analysis:"
        fi

        echo "q" > "$INPUT_INCREMENTAL_TMP"
        
        if $DEBUG; then
            echo "INCREMENTAL COMMANDS:"
            cat "$INPUT_INCREMENTAL_TMP"
        fi

        cmd=(
        timeout "$TIMEOUT"
        "$KASA_INC_BINARY"
        "$EXAMPLE_MODEL"
        -syntax "$SYNTAX"
        $OPTIONS
        --rules-in-working-set "$random_rules"
        )
        printf '%q ' cat "$INPUT_INCREMENTAL_TMP" '|' "${cmd[@]}"
        printf '\n'
        { cat "$INPUT_INCREMENTAL_TMP" | ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_INCREMENTAL"
        EXIT_STATUS=$?

        # Check if the program was killed by timeout
        if [ $EXIT_STATUS -eq 124 ]; then
            echo "⚠️ Timeout or memory overflow occurred for $MODEL in the incremental analysis."
            break
        fi

        echo "<h4>INCREMENTAL ANALYSIS</h4><table>" >> "${OUTPUT_FILE}"

        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Global initialization" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/3_incremental,1_init,1_initialization,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep "End</TD><TD>Initial states computation" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/3_incremental,1_init,2_initial_state,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep -m 1 "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep -m 1 "End</TD><TD>Compute fixpoint of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/3_incremental,1_init,3_fixpoint,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

        grep -m 1 "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" >> "${OUTPUT_FILE}"
        grep -m 1 "End</TD><TD>Print result of reachability analysis" "$PROFILING_FILE" | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/3_incremental,3_print1,4_print,$i,$NR_RULES,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"

    done

    rm "$INPUT_INCREMENTAL_TMP"

    echo "✅ Completed: $MODEL"
    echo "The results of the incremental analysis can be found in: $STDOUT_OUTPUT_FILE_INCREMENTAL"
    echo "And those of the non-incremental analysis in: $STDOUT_OUTPUT_FILE_FULL and $STDOUT_OUTPUT_FILE_REMOVED_RULES"
    echo "The runtimes can be found in: $OUTPUT_FILE"

    # Check for exceptions in STDOUT_OUTPUT_FILE
    if grep -qi "exception:" "$STDOUT_OUTPUT_FILE_FULL"; then
        echo "🚨 Exception raised during analysis of $MODEL 1."
    fi
    if grep -qi "exception:" "$STDOUT_OUTPUT_FILE_INCREMENTAL"; then
        echo "🚨 Exception raised during analysis of $MODEL 3."
    fi 

done

python3 examples/benchmarks/incremental-KaSa/mean_of_reps.py

OUTPUT_MEAN_RUNTIMES="${OUTPUT_DIR}experiments_output_mean.csv"

echo
echo "📝 The mean of all runtimes can be found in: $OUTPUT_MEAN_RUNTIMES"

OUTPUT_LATEX_RUNTIMES="${OUTPUT_DIR}experiments_output_compare_ws.tex"

cmd=(python3 
    "${SCRIPT_DIR}/../../../examples/benchmarks/incremental-KaSa/latex_table_compare_ws.py" 
    "$OUTPUT_MEAN_RUNTIMES" "$OUTPUT_LATEX_RUNTIMES"
    )
        printf '%q ' "${cmd[@]}"
        printf '\n'
        { ${cmd[@]}; }

echo "📊 The latex table of the runtimes can be found in: $OUTPUT_LATEX_RUNTIMES"

