#Download sources/binaries at https://github.com/Kappa-Dev/KaSim
#
#Command line is: KaSa example_agents_params.ka --output-directory output --debugging-mode -syntax 4
#
#This file contains the description of the influence map in dot.
#Please use graphviz (http://www.graphviz.org) or OmniGraffle to export it to a PDF
#
digraph G{
"0:.->A(x{u})" [shape=box fillcolor="#87ceeb" style=filled];
"1:.->B(x{u})" [shape=box fillcolor="#87ceeb" style=filled];

"Au" [shape=ellipse fillcolor="#98fb98" style=filled];
"Bu" [shape=ellipse fillcolor="#98fb98" style=filled];
"0:.->A(x{u})" -> "Au" [label="[0->0]" color="green"];
"1:.->B(x{u})" -> "Bu" [label="[0->0]" color="green"];
}
