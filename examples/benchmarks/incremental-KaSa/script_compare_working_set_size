#!/bin/bash

## BENCHMARKS for the incremental implementation of KaSa, for the Tool paper at CMSB2026

# pre-requisites: python3 with the libraries "pandas" and "matplotlib"

# It analyzer 6 large Kappa models with the incremental analysis, with 0,10,20... rules in the working set.
# Then it outputs a table with the runtime of the analysis for each model depending on the size of the working set.

# The output is in output/experiments_output_compare_ws.tex (table)
# or in output/experiments_output_compare_ws_plot.png (plot)

DEBUG=false
VERBOSE=false
INSTALL_DEPS=false

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${SCRIPT_DIR}/../../.."
PWD=$(pwd)
SCRIPT_DIR=$(realpath "$SCRIPT_DIR" --relative-to="$PWD")

KASA_INC_BINARY="${SCRIPT_DIR}/../../../bin/KaSaIncremental"
KAPPA_OUTPUT_DIR="${SCRIPT_DIR}/../../../output/"
INPUT_INCREMENTAL_TMP="${MODELS_DIRECTORY}inc_analysis_input_tmp.txt"

# default values for variables
TIMEOUT=50m
REPS=10 # how often to repeat each experiment

# help message
print_help() {
    cat << EOF
Usage: ${0} [options]

Options:
  -t <timeout>   Set timeout value (default: $TIMEOUT)
  -r <int>       Set how many reps to do for each experiment (default: $REPS)
  -i             Install dependencies before building and running
  -d             Set DEBUG to true (it runs the analysis with less reps and smaller models)
  -v             Get more verbose output
  -h             Show this help message and exit
EOF
}

# parse arguments
while getopts ":t:r:idvh" opt; do
    case "$opt" in
        t)
            TIMEOUT="$OPTARG"
            ;;
        r)
            REPS="$OPTARG"
            ;;
        i)
            INSTALL_DEPS=true
            ;;
        d)
            DEBUG=true
            ;;
        v)
            VERBOSE=true
            ;;
        h)
            print_help
            exit 0
            ;;
        \?)
            echo "Error: Invalid option -$OPTARG" >&2
            print_help
            exit 1
            ;;
        :)
            echo "Error: Option -$OPTARG requires an argument" >&2
            print_help
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

MIN_NR_RULES=0
MAX_NR_RULES=60
STEP=10

if $DEBUG; then
    MIN_NR_RULES=0
    MAX_NR_RULES=10
    STEP=2
    TIMEOUT=3m
    REPS=2
fi

echo "Using a timeout of $TIMEOUT."
echo "Using $MIN_NR_RULES to $MAX_NR_RULES rules in the working set, with a step of $STEP."
echo "Performing $REPS repetitions for each experiment."

OPTIONS="--reset-all --compute-reachability-analysis --enable-every-domain --print-efficiency"
# models
MODELS_DIRECTORY="${SCRIPT_DIR}/models/"

egfr_net="${MODELS_DIRECTORY}egfr_net.ka"

korkut_20170206="${MODELS_DIRECTORY}korkut/20170206/korkut_model.ka"
korkut_20170113="${MODELS_DIRECTORY}korkut/20170113/prior_model.ka"
wnt_20170322="${MODELS_DIRECTORY}wnt/20170322/full_model.ka"
wnt_20151228="${MODELS_DIRECTORY}wnt/20151228/model_bigwnt.ka"
tgf_v19="${MODELS_DIRECTORY}tgf/V19/NTactivationTGF_19.ka"
tgf_20180419="${MODELS_DIRECTORY}tgf/20180419/full.ka"


# To find the number of rules (not fool-proof):
# grep -v "^/\*" model | grep -v "^#" - | grep -c -- "->" -
korkut_20170206_nr_rules=5750
korkut_20170113_nr_rules=3916
wnt_20170322_nr_rules=1470
wnt_20151228_nr_rules=356
egfr_net_nr_rules=23
tgf_20180419_nr_rules=292
tgf_v19_nr_rules=97


# Array of models
MODELS=("tgf_v19" "tgf_20180419" "wnt_20151228" "wnt_20170322" "korkut_20170113" "korkut_20170206")

OUTPUT_DIR="${SCRIPT_DIR}/output/"
PROFILING_FILE="${KAPPA_OUTPUT_DIR}profiling.html"

if $DEBUG ; then
    MODELS=("egfr_net" "tgf_20180419" "wnt_20151228")
fi

AVAILABLE_MODELS=$(printf "%s, " "${MODELS[@]}")
AVAILABLE_MODELS=${AVAILABLE_MODELS%, }

if $INSTALL_DEPS; then
    # Install the dependencies
    echo "Installing dependencies:"
    opam install . --update-invariant
fi

if ! $DEBUG; then
    echo
    # Build Kappa
    echo "Building the project:"
    make all
fi

mkdir -p "${OUTPUT_DIR}"

echo
echo "Analyzing models: $AVAILABLE_MODELS"

GLOBAL_OUTPUT_FILE="${OUTPUT_DIR}experiments_output.csv"
echo "analysis_type,step_name,substep_name,rep,nr_removed_rules,time" > "$GLOBAL_OUTPUT_FILE"

store_runtime_from_profiling () {
    # take the line we are interested in from profiling.html and copy the runtime to the output file in a csv format
    grep --text "End</TD><TD>$1" "$PROFILING_FILE" | tail -1 | sed -e "s/[^0-9.-]//g" -e "s/[0-9.-]*/$2,&/g" -e 's/-/e-/g' >> "${GLOBAL_OUTPUT_FILE}"
}

# Analyze each model
for MODEL in "${MODELS[@]}"; do
    EXAMPLE_MODEL=${!MODEL}
    var_tmp="${MODEL}_nr_rules"
    value_tmp=${!var_tmp}
    NR_RULES_MODEL=$((value_tmp-1))

    # Analyze the model for each size of working set
    for ((NR_RULES=MIN_NR_RULES; NR_RULES <= MAX_NR_RULES; NR_RULES=NR_RULES+STEP)) do
        echo
        echo "Processing model: $MODEL with $NR_RULES rules in the working set"

        # output file
        STDOUT_OUTPUT_FILE_INCREMENTAL="${OUTPUT_DIR}${NR_RULES}_rules_in_ws_experiments_output_incremental_$MODEL.txt"
   
        # clear output file
        echo -n "" > "$STDOUT_OUTPUT_FILE_INCREMENTAL"

        SYNTAX="V4"
        if grep -v "^/\*" "$EXAMPLE_MODEL" | grep -qi "!1" -; then
            SYNTAX="V3"
        fi

        for (( i=1; i<=REPS; i++ ))
        do
            # INCREMENTAL ANALYSIS
            if $VERBOSE; then
                echo "⚡️ Starting incremental analysis:"
            fi

            echo "q" > "$INPUT_INCREMENTAL_TMP"
            
            if $VERBOSE; then
                echo "INCREMENTAL COMMANDS:"
                cat "$INPUT_INCREMENTAL_TMP"
            fi

            if ((NR_RULES==0)); then 
                cmd=(
                timeout "$TIMEOUT"
                "$KASA_INC_BINARY"
                "$EXAMPLE_MODEL"
                -syntax "$SYNTAX"
                $OPTIONS
                )
            else 
                random_rules=$(shuf -i "0-$NR_RULES_MODEL" -n $NR_RULES | paste -s -d ',')
                cmd=(
                timeout "$TIMEOUT"
                "$KASA_INC_BINARY"
                "$EXAMPLE_MODEL"
                -syntax "$SYNTAX"
                $OPTIONS
                --rules-in-working-set "$random_rules"
                )
            fi
            if $VERBOSE; then
                printf '%q ' cat "$INPUT_INCREMENTAL_TMP" '|' "${cmd[@]}"
                printf '\n'
            fi
            { cat "$INPUT_INCREMENTAL_TMP" | ${cmd[@]}; } >> "$STDOUT_OUTPUT_FILE_INCREMENTAL"
            EXIT_STATUS=$?

            # Check if the program was killed by timeout
            if [ $EXIT_STATUS -eq 124 ]; then
                echo "⚠️ Timeout or memory overflow occurred for $MODEL in the incremental analysis."
                break
            fi

            store_runtime_from_profiling "Global initialization" "$MODEL,$MODEL,1_initialization,$i,$NR_RULES"
            store_runtime_from_profiling "Initial states computation" "$MODEL,$MODEL,2_initial_state,$i,$NR_RULES"
            store_runtime_from_profiling "Compute fixpoint of reachability analysis" "$MODEL,$MODEL,3_fixpoint,$i,$NR_RULES"
        done

        rm "$INPUT_INCREMENTAL_TMP"

        echo "✅ Completed: $MODEL with $NR_RULES rules in the working set."
        echo "The results of the incremental analysis can be found in: $STDOUT_OUTPUT_FILE_INCREMENTAL"
    done
done

python3 examples/benchmarks/incremental-KaSa/mean_of_reps.py "${OUTPUT_DIR}experiments_output.csv" "${OUTPUT_DIR}experiments_output_mean.csv"

OUTPUT_MEAN_RUNTIMES="${OUTPUT_DIR}experiments_output_mean.csv"

echo
echo "📝 The mean of all runtimes can be found in: $OUTPUT_MEAN_RUNTIMES"

OUTPUT_LATEX_RUNTIMES="${OUTPUT_DIR}experiments_output_compare_ws.tex"

cmd=(python3 
    "${SCRIPT_DIR}/latex_table_compare_ws.py" 
    "$OUTPUT_MEAN_RUNTIMES" "$OUTPUT_LATEX_RUNTIMES"
    )
if $VERBOSE; then
    printf '%q ' "${cmd[@]}"
    printf '\n'
fi
{ ${cmd[@]}; }

echo "📊 The latex table of the runtimes can be found in: $OUTPUT_LATEX_RUNTIMES"

cmd=(python3 
    "${SCRIPT_DIR}/plot.py" "${OUTPUT_DIR}experiments_output_mean.csv" "${OUTPUT_DIR}runtimes"
    )
printf '%q ' "${cmd[@]}"
printf '\n'
{ ${cmd[@]}; }
echo "📈 The png plot of the runtimes can be found in: ${OUTPUT_DIR}runtimes.png"
