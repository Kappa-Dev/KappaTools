		v B(y[y.A]) [ only if test1.and.test2 ]]
C(x)=> [
		  C(x[.]) [ only if (test1.or.test3).and.((.not.test1).or.test2.or.test3) ]
		v C(x[x.A]) [ only if (test1.or.test3).and.((.not.test1).or.test2.or.test3) ]]

